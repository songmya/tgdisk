# =========================================================
# TGDrive 环境配置（复制为 .env 后填好真实值）
# =========================================================

# ===== 必填 =====

# Bot Token（向 @BotFather 申请；格式通常为 数字:字符串）
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 管理员 Telegram ID（多个用逗号分隔；获取：给 @userinfobot 发消息）
ADMIN_IDS=YOUR_TELEGRAM_ID

# ===== 代理 =====
# 国内机器访问官方 api.telegram.org 通常需要代理。
# 如果代理跑在宿主机 127.0.0.1，容器内访问不到 127.0.0.1；请改用宿主机 LAN IP，
# 或在 docker-compose.yml 中使用 network_mode: host。
# PROXY=http://user:pass@host:port
# PROXY=socks5://user:pass@host:port

# ===== 可选：自建 Bot API Server（减少 Bot API 50MB/20MB 限制影响）=====
# LOCAL_API_BASE=http://botapi:8081
# LOCAL_API_MODE=true

# ===== 数据 =====
DB_PATH=data/tgdrive.sqlite3

# ===== 上传策略 =====
# 应用层最大文件大小（MB）。0 = 不限。
MAX_FILE_SIZE=0

# 并发上传 Telegram 分片数。每片约 18MB，峰值内存约 N×18MB。
UPLOAD_CONCURRENCY=4

# ===== WebUI 上传缓存 =====
# WebUI 上传先写入缓存，再后台上传 Telegram；可显示双阶段进度。
UPLOAD_CACHE_ENABLED=true
UPLOAD_CACHE_DIR=data/cache

# 缓存总容量上限（MB）。超限会拒绝新任务，并清理过期/已完成任务。
UPLOAD_CACHE_MAX_SIZE_MB=10240

# 单个缓存文件上限（MB）。0 = 不限制。
UPLOAD_CACHE_MAX_FILE_SIZE_MB=0

# 失败/取消/未完成缓存保留时间（小时）。
UPLOAD_CACHE_TTL_HOURS=24

# Telegram 上传完成后是否保留缓存文件。默认 false，完成即删除缓存文件。
UPLOAD_CACHE_KEEP_AFTER_DONE=false

# 浏览器上传到服务器缓存时的分片大小（字节），默认 8MiB。
BROWSER_CHUNK_SIZE=8388608

# ===== 杂项 =====
PAGE_SIZE=20
LOG_LEVEL=INFO

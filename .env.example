# TGDrive 环境配置

# === 必填 ===
# Bot Token（从 @BotFather 获取）
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 管理员 Telegram ID（逗号分隔，获取方式：给 @userinfobot 发消息）
ADMIN_IDS=YOUR_TELEGRAM_ID

# === 可选 ===
# 代理地址（国内机器连官方 api.telegram.org 需要，连自建服务器一般不需要）
# HTTP 代理
PROXY=http://127.0.0.1:7890
# SOCKS5 代理
# PROXY=socks5://127.0.0.1:1080

# === 自建 Bot API Server（可选）===
# 填了 LOCAL_API_BASE 后，aiogram 会走自建端点，单文件限制可提升到 2GB
# LOCAL_API_BASE=http://127.0.0.1:8081
# 本地模式：Bot 与 Bot API Server 同机部署时开启，下载接口返回本地绝对路径
# LOCAL_API_MODE=true

# 数据库路径
DB_PATH=data/tgdrive.sqlite3

# 最大文件大小（MB）。0 = 不限（推荐）
# 设为其他值可以设个应用层安全阀，避免误传超大文件搎临时盘
MAX_FILE_SIZE=0

# 并发上传分片数（包含 webui 和 webdav）
# 每片 18MB，并发 N 个则峰值内存 = N×18MB。推荐 4，上限取决于 Telegram 限速
UPLOAD_CONCURRENCY=4

# 每页显示文件数
PAGE_SIZE=20

# 日志级别
LOG_LEVEL=INFO
